# --- APIs externas ---
GOOGLE_PLACES_API_KEY=
NOTION_TOKEN=
NOTION_DATABASE_ID=

# --- Servidor ---
PORT=3000

# --- Auth (producción) ---
# Si ACCESS_PASSWORD queda vacío, no se pide login (dev local).
# En Railway, poné una contraseña fuerte.
ACCESS_USER=admin
ACCESS_PASSWORD=

# --- Persistencia ---
# Local: dejar vacío → usa ./data
# Railway: DATA_DIR=/data (ruta del volume montado)
DATA_DIR=

# --- Railway flags ---
# false = no escribir .env desde el endpoint /api/config/save.
# En Railway dejarlo en false; las keys se setean en el dashboard.
ALLOW_ENV_WRITE=true
